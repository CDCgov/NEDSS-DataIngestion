# NBS7_DPS_PORT=8082
# NBS7_DPS_CONTEXT_PATH=/rti

# NBS7_DIS_HOST=localhost
# NBS7_DIS_PORT=8081
# NBS7_DIS_CONTEXT_PATH=/ingestion

# NBS7_CLIENT_ID=di-keycloak-client
